{
  "manifest_version": 3,
  "name": "AI Chat Exporter",
  "version": "1.8.0",
  "description": "Export conversations from Claude, ChatGPT, Gemini, and Microsoft Copilot as HTML, ZIP, Markdown, or PDF files",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "contextMenus"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://m365.cloud.microsoft/*",
    "https://copilot.microsoft.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["platforms/claude/content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["platforms/chatgpt/content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["platforms/gemini/content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://m365.cloud.microsoft/*", "https://copilot.microsoft.com/*"],
      "js": ["platforms/copilot/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "platforms/claude/injector.js",
        "platforms/chatgpt/injector.js",
        "jszip.min.js"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
